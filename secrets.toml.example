# Arquivo de exemplo — NÃO coloque sua chave real aqui!
# Este arquivo é apenas uma referência de como configurar os Secrets.
#
# Para configurar no Streamlit Community Cloud:
#   1. Acesse o painel do seu app em share.streamlit.io
#   2. Clique em ⋮ → Settings → Secrets
#   3. Cole o conteúdo abaixo substituindo pelo valor real:
#
# ANTHROPIC_API_KEY = "sk-ant-sua-chave-aqui"
#
# Para rodar localmente com IA:
#   1. Copie este arquivo: cp secrets.toml.example .streamlit/secrets.toml
#   2. Edite .streamlit/secrets.toml com sua chave real
#   (o arquivo secrets.toml está no .gitignore e nunca será enviado ao GitHub)

ANTHROPIC_API_KEY = "sk-ant-SUBSTITUA-PELA-SUA-CHAVE"
